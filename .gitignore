## Ignore Visual Studio temporary files, build results, and
## user-specific files

# Build results
bin/
obj/
out/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# OS generated files
.DS_Store
Thumbs.db

# Rider-specific
.idea/

# Visual Studio Code settings
.vscode/

# NuGet packages
*.nupkg
*.snupkg
*.nuspec
packages/
project.lock.json
project.fragment.lock.json

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Others
*.log
*.tlog
*.cache
*.pdb
*.mdb
*.bak

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Publish outputs
publish/
